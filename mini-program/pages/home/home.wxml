<view class="container">
  <view class="card profile-card">
    <view class="username">{{user.username || user.phone}}</view>
    <view class="phone">{{user.phone}}</view>
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>

  <view class="card sign-card">
    <view class="section-title">每日签到</view>
    <view class="stats-row">
      <view class="stat">
        <view class="stat-label">累计签到</view>
        <view class="stat-value">{{totalSignedDays}}</view>
      </view>
      <view class="stat">
        <view class="stat-label">连续天数</view>
        <view class="stat-value">{{continuousDays}}</view>
      </view>
      <view class="stat">
        <view class="stat-label">抽奖机会</view>
        <view class="stat-value">{{drawChances}}</view>
      </view>
    </view>
    <button class="sign-btn {{signedToday ? 'signed' : ''}}" bindtap="handleCheckin">
      {{signedToday ? '今日已签到' : '立即签到 +1 抽奖机会'}}
    </button>
  </view>

  <view class="card lottery-card">
    <view class="section-title">抽奖转盘</view>
    <view class="wheel-wrap">
      <view class="wheel" style="transform: rotate({{wheelDeg}}deg);">
        <block wx:for="{{prizes}}" wx:key="key" wx:for-item="item" wx:for-index="index">
          <view class="slice-label slice-{{index}}">{{item.name}}</view>
        </block>
      </view>
      <view class="pointer">▼</view>
    </view>
    <button class="spin-btn" loading="{{spinning}}" bindtap="handleSpin">开始抽奖</button>
    <view class="latest-prize" wx:if="{{latestPrizeName}}">最近抽中：{{latestPrizeName}}</view>
  </view>

  <view class="card logs-card">
    <view class="section-title">最近中奖记录</view>
    <view class="log-empty" wx:if="{{logs.length === 0}}">暂无记录</view>
    <block wx:for="{{logs}}" wx:key="id" wx:for-item="item">
      <view class="log-item">
        <view class="log-prize">{{item.prize_name}}</view>
        <view class="log-time">{{item.created_at}}</view>
      </view>
    </block>
  </view>
</view>
