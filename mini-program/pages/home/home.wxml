<view class="container">
  <view class="card profile-card">
    <view class="username">{{user.username || "Guest"}}</view>
    <view class="phone">{{user.phone}}</view>
    <button class="logout-btn" bindtap="handleLogout">Logout</button>
  </view>

  <view class="card sign-card">
    <view class="section-title">Daily Check-in</view>
    <view class="stats-row">
      <view class="stat">
        <view class="stat-label">Total</view>
        <view class="stat-value">{{totalSignedDays}}</view>
      </view>
      <view class="stat">
        <view class="stat-label">Streak</view>
        <view class="stat-value">{{continuousDays}}</view>
      </view>
      <view class="stat">
        <view class="stat-label">Chances</view>
        <view class="stat-value">{{drawChances}}</view>
      </view>
    </view>
    <button class="sign-btn {{signedToday ? 'signed' : ''}}" bindtap="handleCheckin">
      {{signedToday ? 'Checked in today' : 'Check in +1 chance'}}
    </button>
  </view>

  <view class="card lottery-card">
    <view class="section-title">Lucky Wheel</view>
    <view class="wheel-wrap">
      <view class="wheel" style="transform: rotate({{wheelDeg}}deg);">
        <block wx:for="{{prizes}}" wx:key="key" wx:for-item="item" wx:for-index="index">
          <view class="slice-label slice-{{index}}">{{item.name}}</view>
        </block>
      </view>
      <view class="pointer">▲</view>
    </view>
    <button class="spin-btn" loading="{{spinning}}" bindtap="handleSpin">Spin Now</button>
    <view class="latest-prize" wx:if="{{latestPrizeName}}">Latest: {{latestPrizeName}}</view>
  </view>

  <view class="card logs-card">
    <view class="section-title">Recent Draw Logs</view>
    <view class="log-empty" wx:if="{{logs.length === 0}}">No records</view>
    <block wx:for="{{logs}}" wx:key="id" wx:for-item="item">
      <view class="log-item">
        <view class="log-prize">{{item.prize_name}}</view>
        <view class="log-time">{{item.created_at}}</view>
      </view>
    </block>
  </view>
</view>
