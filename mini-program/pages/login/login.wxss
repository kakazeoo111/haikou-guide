.container {
  min-height: 100vh;
  padding: 70rpx 36rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e7f6ee 0%, #f5faf8 100%);
}

.hero {
  margin-bottom: 36rpx;
}

.title {
  font-size: 50rpx;
  font-weight: 700;
  color: #1d2a24;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #6f7c75;
}

.login-card {
  padding: 36rpx 28rpx;
}

.one-click-btn {
  height: 92rpx;
  border-radius: 24rpx;
  border: none;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
  background: linear-gradient(135deg, #5aa77b 0%, #3f9267 100%);
}
