# Backend port
SMS_SERVER_PORT=3001

# Aliyun SMS credentials (do NOT commit your real secrets)
ALIBABA_CLOUD_ACCESS_KEY_ID=your_access_key_id
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your_access_key_secret
ALIBABA_CLOUD_SMS_SIGN_NAME=your_sms_sign_name
ALIBABA_CLOUD_SMS_TEMPLATE_CODE=your_sms_template_code

# Optional: the variable name used in your Aliyun SMS template JSON, default is "code"
ALIBABA_CLOUD_SMS_CODE_PARAM_NAME=code

# Optional endpoint override (normally no need to change)
ALIBABA_CLOUD_SMS_ENDPOINT=https://dysmsapi.aliyuncs.com/

# Optional behavior tuning (milliseconds)
SMS_CODE_EXPIRE_MS=your_sms_code_expire_ms
SMS_SEND_COOLDOWN_MS=your_sms_send_cooldown_ms

# WeChat Mini Program
WECHAT_MINI_APPID=your_wechat_mini_appid
WECHAT_MINI_APPSECRET=your_wechat_mini_appsecret
